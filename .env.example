# ─── ConsensusAI environment ───────────────────────────────────────────
# Copy this file to `.env.local` and fill in your values.

# ── LLM (Moderator Agent) ─────────────────────────────────────────────
# OpenRouter (default):
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_API_KEY=sk-or-...
#   LLM_MODEL=openai/gpt-4o-mini
#
# Qwen (hackathon credits):
#   LLM_BASE_URL=https://hackathon.bitgetops.com/v1
#   LLM_API_KEY=<your Qwen token>
#   LLM_MODEL=qwen3.6-plus

LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini

# Legacy aliases (still read if LLM_ vars are empty)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ── MCP Bridge (optional — only needed for Vercel) ────────────────────
# Deploy bridge/ to Railway/Render and set the public URL here.
# Leave blank for local dev (MCP servers spawn as child processes).
BRIDGE_URL=

# ── Supabase (optional in dev, needed for history) ────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
